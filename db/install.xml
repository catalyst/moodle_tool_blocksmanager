<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="admin/tool/blocksmanager/db" VERSION="20191220" COMMENT="XMLDB file for Moodle admin/tool/blocksmanager"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="tool_blocksmanager_blocks" COMMENT="Blocks data">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="categories" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="blockname" TYPE="char" LENGTH="200" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="visibility" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1" SEQUENCE="false"/>
        <FIELD NAME="primaryweight" TYPE="char" LENGTH="16" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="primaryregion" TYPE="char" LENGTH="16" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="secondaryweight" TYPE="char" LENGTH="16" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="secondaryregion" TYPE="char" LENGTH="16" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="actions" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
    </TABLE>
  </TABLES>
</XMLDB>